{
  "manifest_version": 3,
  "name": "Memex Browser Recall",
  "version": "0.1.0",
  "description": "Capture and recall browser sessions using semantic memory.",
  "permissions": ["storage", "tabs", "history"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "Memex Recall"
  },
  "background": {
    "service_worker": "background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
